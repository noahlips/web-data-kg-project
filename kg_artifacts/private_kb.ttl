prop:brandName a owl:DatatypeProperty .

prop:genericName a owl:DatatypeProperty .

prop:hasActiveIngredient a owl:ObjectProperty ;
    rdfs:domain med:Drug ;
    rdfs:range med:ActiveIngredient .

prop:hasDosageForm a owl:ObjectProperty ;
    rdfs:domain med:Drug ;
    rdfs:range med:DosageForm .

prop:hasManufacturer a owl:ObjectProperty ;
    rdfs:domain med:Drug ;
    rdfs:range med:Manufacturer .

prop:hasRoute a owl:ObjectProperty ;
    rdfs:domain med:Drug ;
    rdfs:range med:Route .

