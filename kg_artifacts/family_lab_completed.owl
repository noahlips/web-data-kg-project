<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/family#"
     xml:base="http://www.semanticweb.org/family"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#">

    <owl:Ontology rdf:about="http://www.semanticweb.org/family"/>

    <!-- DATA PROPERTIES -->
    <owl:DatatypeProperty rdf:about="#name">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="#Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#age">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="#Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#nationality">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="#Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <!-- OBJECT PROPERTIES -->
    <owl:ObjectProperty rdf:about="#isMarriedWith">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdfs:domain rdf:resource="#Person"/>
        <rdfs:range rdf:resource="#Person"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#isParentOf">
        <rdfs:domain rdf:resource="#Person"/>
        <rdfs:range rdf:resource="#Person"/>
        <owl:inverseOf rdf:resource="#isChildOf"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#isFatherOf">
        <rdfs:subPropertyOf rdf:resource="#isParentOf"/>
        <rdfs:domain rdf:resource="#Male"/>
        <rdfs:range rdf:resource="#Person"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#isMotherOf">
        <rdfs:subPropertyOf rdf:resource="#isParentOf"/>
        <rdfs:domain rdf:resource="#Female"/>
        <rdfs:range rdf:resource="#Person"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#isSiblingOf">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="#Person"/>
        <rdfs:range rdf:resource="#Person"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#isBrotherOf">
        <rdfs:subPropertyOf rdf:resource="#isSiblingOf"/>
        <rdfs:domain rdf:resource="#Male"/>
        <rdfs:range rdf:resource="#Person"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#isSisterOf">
        <rdfs:subPropertyOf rdf:resource="#isSiblingOf"/>
        <rdfs:domain rdf:resource="#Female"/>
        <rdfs:range rdf:resource="#Person"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#isChildOf">
        <rdfs:domain rdf:resource="#Person"/>
        <rdfs:range rdf:resource="#Person"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#isSonOf">
        <rdfs:subPropertyOf rdf:resource="#isChildOf"/>
        <rdfs:domain rdf:resource="#Male"/>
        <rdfs:range rdf:resource="#Person"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#isDaughterOf">
        <rdfs:subPropertyOf rdf:resource="#isChildOf"/>
        <rdfs:domain rdf:resource="#Female"/>
        <rdfs:range rdf:resource="#Person"/>
    </owl:ObjectProperty>

    <!-- CLASSES -->
    <owl:Class rdf:about="#Person"/>

    <owl:Class rdf:about="#Male">
        <rdfs:subClassOf rdf:resource="#Person"/>
        <owl:disjointWith rdf:resource="#Female"/>
    </owl:Class>

    <owl:Class rdf:about="#Female">
        <rdfs:subClassOf rdf:resource="#Person"/>
    </owl:Class>

    <owl:Class rdf:about="#Parent">
        <rdfs:subClassOf rdf:resource="#Person"/>
    </owl:Class>

    <owl:Class rdf:about="#Child">
        <rdfs:subClassOf rdf:resource="#Person"/>
    </owl:Class>

    <owl:Class rdf:about="#Sibling">
        <rdfs:subClassOf rdf:resource="#Person"/>
    </owl:Class>

    <owl:Class rdf:about="#Grandparents">
        <rdfs:subClassOf rdf:resource="#Person"/>
    </owl:Class>

    <!-- Father = Male AND isFatherOf some Person -->
    <owl:Class rdf:about="#Father">
        <rdfs:subClassOf rdf:resource="#Parent"/>
        <rdfs:subClassOf rdf:resource="#Male"/>
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Class rdf:about="#Male"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="#isFatherOf"/>
                        <owl:someValuesFrom rdf:resource="#Person"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <owl:disjointWith rdf:resource="#Mother"/>
    </owl:Class>

    <!-- Mother = Female AND isMotherOf some Person -->
    <owl:Class rdf:about="#Mother">
        <rdfs:subClassOf rdf:resource="#Parent"/>
        <rdfs:subClassOf rdf:resource="#Female"/>
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Class rdf:about="#Female"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="#isMotherOf"/>
                        <owl:someValuesFrom rdf:resource="#Person"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>

    <!-- Son = Male AND isSonOf some Person -->
    <owl:Class rdf:about="#Son">
        <rdfs:subClassOf rdf:resource="#Child"/>
        <rdfs:subClassOf rdf:resource="#Male"/>
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Class rdf:about="#Male"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="#isSonOf"/>
                        <owl:someValuesFrom rdf:resource="#Person"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <owl:disjointWith rdf:resource="#Daughter"/>
    </owl:Class>

    <!-- Daughter = Female AND isDaughterOf some Person -->
    <owl:Class rdf:about="#Daughter">
        <rdfs:subClassOf rdf:resource="#Child"/>
        <rdfs:subClassOf rdf:resource="#Female"/>
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Class rdf:about="#Female"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="#isDaughterOf"/>
                        <owl:someValuesFrom rdf:resource="#Person"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>

    <!-- Brother = Male AND isBrotherOf some Person -->
    <owl:Class rdf:about="#Brother">
        <rdfs:subClassOf rdf:resource="#Sibling"/>
        <rdfs:subClassOf rdf:resource="#Male"/>
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Class rdf:about="#Male"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="#isBrotherOf"/>
                        <owl:someValuesFrom rdf:resource="#Person"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>

    <!-- Sister = Female AND isSisterOf some Person -->
    <owl:Class rdf:about="#Sister">
        <rdfs:subClassOf rdf:resource="#Sibling"/>
        <rdfs:subClassOf rdf:resource="#Female"/>
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Class rdf:about="#Female"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="#isSisterOf"/>
                        <owl:someValuesFrom rdf:resource="#Person"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>

    <!-- Uncle = Male AND isBrotherOf some (Person AND isParentOf some Person) -->
    <owl:Class rdf:about="#Uncle">
        <rdfs:subClassOf rdf:resource="#Person"/>
        <rdfs:subClassOf rdf:resource="#Male"/>
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Class rdf:about="#Male"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="#isBrotherOf"/>
                        <owl:someValuesFrom>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="#isParentOf"/>
                                <owl:someValuesFrom rdf:resource="#Person"/>
                            </owl:Restriction>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>

    <!-- Grandfather = Male AND isFatherOf some (Person AND isParentOf some Person) -->
    <owl:Class rdf:about="#Grandfather">
        <rdfs:subClassOf rdf:resource="#Grandparents"/>
        <rdfs:subClassOf rdf:resource="#Male"/>
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Class rdf:about="#Male"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="#isFatherOf"/>
                        <owl:someValuesFrom>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="#isParentOf"/>
                                <owl:someValuesFrom rdf:resource="#Person"/>
                            </owl:Restriction>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <owl:disjointWith rdf:resource="#Grandmother"/>
    </owl:Class>

    <!-- Grandmother = Female AND isMotherOf some (Person AND isParentOf some Person) -->
    <owl:Class rdf:about="#Grandmother">
        <rdfs:subClassOf rdf:resource="#Grandparents"/>
        <rdfs:subClassOf rdf:resource="#Female"/>
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Class rdf:about="#Female"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="#isMotherOf"/>
                        <owl:someValuesFrom>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="#isParentOf"/>
                                <owl:someValuesFrom rdf:resource="#Person"/>
                            </owl:Restriction>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>

    <!-- INDIVIDUALS -->
    <owl:NamedIndividual rdf:about="#Peter">
        <rdf:type rdf:resource="#Male"/>
        <name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Peter</name>
        <age rdf:datatype="http://www.w3.org/2001/XMLSchema#int">70</age>
        <nationality rdf:datatype="http://www.w3.org/2001/XMLSchema#string">French</nationality>
        <isMarriedWith rdf:resource="#Marie"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#Thomas">
        <rdf:type rdf:resource="#Male"/>
        <name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Thomas</name>
        <age rdf:datatype="http://www.w3.org/2001/XMLSchema#int">40</age>
        <nationality rdf:datatype="http://www.w3.org/2001/XMLSchema#string">French</nationality>
        <isSonOf rdf:resource="#Peter"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#Paul">
        <rdf:type rdf:resource="#Male"/>
        <name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Paul</name>
        <age rdf:datatype="http://www.w3.org/2001/XMLSchema#int">38</age>
        <isSonOf rdf:resource="#Peter"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#John">
        <rdf:type rdf:resource="#Male"/>
        <name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">John</name>
        <age rdf:datatype="http://www.w3.org/2001/XMLSchema#int">45</age>
        <nationality rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Italian</nationality>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#Pedro">
        <rdf:type rdf:resource="#Male"/>
        <name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pedro</name>
        <age rdf:datatype="http://www.w3.org/2001/XMLSchema#int">10</age>
        <isSonOf rdf:resource="#John"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#Tom">
        <rdf:type rdf:resource="#Male"/>
        <name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Tom</name>
        <age rdf:datatype="http://www.w3.org/2001/XMLSchema#int">10</age>
        <isSonOf rdf:resource="#Thomas"/>
        <isSonOf rdf:resource="#Alex"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#Michael">
        <rdf:type rdf:resource="#Male"/>
        <name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Michael</name>
        <age rdf:datatype="http://www.w3.org/2001/XMLSchema#int">5</age>
        <isSonOf rdf:resource="#Thomas"/>
        <isSonOf rdf:resource="#Alex"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#Marie">
        <rdf:type rdf:resource="#Female"/>
        <name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Marie</name>
        <age rdf:datatype="http://www.w3.org/2001/XMLSchema#int">69</age>
        <nationality rdf:datatype="http://www.w3.org/2001/XMLSchema#string">French</nationality>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#Sylvie">
        <rdf:type rdf:resource="#Female"/>
        <name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sylvie</name>
        <age rdf:datatype="http://www.w3.org/2001/XMLSchema#int">30</age>
        <isDaughterOf rdf:resource="#Marie"/>
        <isDaughterOf rdf:resource="#Peter"/>
        <isMarriedWith rdf:resource="#John"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#Chloe">
        <rdf:type rdf:resource="#Female"/>
        <name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Chloe</name>
        <age rdf:datatype="http://www.w3.org/2001/XMLSchema#int">18</age>
        <isDaughterOf rdf:resource="#Marie"/>
        <isDaughterOf rdf:resource="#Peter"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#Claude_Person">
        <rdf:type rdf:resource="#Female"/>
        <name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Claude</name>
        <age rdf:datatype="http://www.w3.org/2001/XMLSchema#int">5</age>
        <nationality rdf:datatype="http://www.w3.org/2001/XMLSchema#string">French</nationality>
        <isDaughterOf rdf:resource="#Sylvie"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#Alex">
        <rdf:type rdf:resource="#Female"/>
        <name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Alex</name>
        <age rdf:datatype="http://www.w3.org/2001/XMLSchema#int">25</age>
        <isMarriedWith rdf:resource="#Thomas"/>
    </owl:NamedIndividual>

</rdf:RDF>